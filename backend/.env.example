# claude-deploy backend config
# Copy to .env for local dev, or set these in Railway's variables panel.

# Railway PROJECT token (not an account/team token) scoped to the user-apps
# project + environment. Create via the Railway GraphQL API:
#
#   mutation { projectTokenCreate(input: { projectId, environmentId, name }) }
#
# or in the dashboard: Project → Settings → Tokens.
#
# Project tokens encode their target project + environment, so the Railway
# CLI auto-targets the right place without `railway link`. This is critical
# because when the backend runs on Railway itself, the CLI ignores
# `--project` flags (it reads project info from the container runtime).
CD_TARGET_TOKEN=

# Optional: require clients to send `Authorization: Bearer <token>`.
# Leave blank for an open backend (not recommended for public URLs).
CLIENT_TOKEN=

# Optional tuning
PORT=3000
MAX_UPLOAD_BYTES=52428800
DEPLOY_TIMEOUT_MS=900000
RATE_LIMIT_PER_MIN=6
SERVICE_NAME_PREFIX=cd
